# Seed del primer admin (solo si la tabla usuarios esta vacia)
API_KEY=cambia-esta-api-key-larga-y-aleatoria

# JWT para el dashboard React
JWT_SECRET=cambia-este-jwt-secret

# Compatibilidad; JWT_SECRET tiene prioridad
SESSION_SECRET=cambia-este-secret

PORT=3000

# Postgres
DATABASE_URL=postgresql://auditoria:auditoria@localhost:5432/auditoria
POSTGRES_USER=auditoria
POSTGRES_PASSWORD=auditoria
POSTGRES_DB=auditoria

# Origen permitido del frontend (CORS)
CORS_ORIGIN=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# URL del API que ve el browser al compilar el frontend
VITE_API_URL=http://localhost:3000

# Generacion de PDF con opencode
OPENCODE_MODEL=zai/glm-5.1
OPENCODE_TIMEOUT_MS=600000
ZAI_API_KEY=
