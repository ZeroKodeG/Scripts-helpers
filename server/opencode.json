{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "bitfrost": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Bitfrost",
      "options": {
        "baseURL": "{env:BITFROST_BASE_URL}",
        "headers": {
          "x-bf-vk": "{env:BITFROST_API_KEY}"
        }
      },
      "models": {
        "zerokode-auto": {
          "name": "Zerokode",
          "limit": {
            "context": 200000,
            "output": 32768
          }
        }
      }
    }
  }
}
