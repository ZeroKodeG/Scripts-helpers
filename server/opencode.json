{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "zai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ZAI Coding Plan",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "headers": {
          "Authorization": "Bearer {env:ZAI_API_KEY}"
        }
      },
      "models": {
        "glm-5.1": {
          "name": "GLM-5.1",
          "limit": {
            "context": 200000,
            "output": 128000
          }
        },
        "glm-5.2": {
          "name": "GLM-5.2",
          "limit": {
            "context": 200000,
            "output": 128000
          }
        }
      }
    }
  }
}
