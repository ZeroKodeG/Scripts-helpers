<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Auditoria - Ingresar</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-shell">
  <div class="top-strip"></div>
  <div class="login-center">
    <div class="login-card">
      <div class="logo-container">
        <!-- Shield Lock Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      </div>
      <p class="eyebrow">Auditoria</p>
      <h1>Ingresar al panel</h1>
      <p class="hint">Usa la API key del backend para ver los reportes de los equipos.</p>

      <% if (error) { %>
        <div class="alert alert-error">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          <%= error %>
        </div>
      <% } %>

      <form method="post" action="/login">
        <div class="field">
          <label for="api_key">API Key</label>
          <input type="password" id="api_key" name="api_key" autofocus required autocomplete="current-password" placeholder="••••••••••••••••">
        </div>
        <button class="btn-primary" type="submit">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 0-7.778 7.778 5.5 5.5 0 0 0 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
          Ingresar
        </button>
      </form>
    </div>
  </div>
</body>
</html>
