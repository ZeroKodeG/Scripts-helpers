# Copiar a server/.env (y opcionalmente .env en la raiz para compose)

API_KEY=cambia-esta-key-por-una-larga-y-aleatoria
JWT_SECRET=cambia-este-jwt-secret
SESSION_SECRET=cambia-este-secret-tambien
PORT=3000

POSTGRES_USER=auditoria
POSTGRES_PASSWORD=auditoria
POSTGRES_DB=auditoria
DATABASE_URL=postgresql://auditoria:auditoria@localhost:5432/auditoria

CORS_ORIGIN=http://localhost:8080
VITE_API_URL=http://localhost:3000
FRONTEND_PORT=8080

OPENCODE_MODEL=zai/glm-5.1
OPENCODE_TIMEOUT_MS=600000
ZAI_API_KEY=
